# 复制本文件为 .env，填入真实 Key
# .env 已加入 .gitignore，不会被提交到仓库

DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选
PORT=3001
DEEPSEEK_MODEL=deepseek-chat
# 切换推理模型：DEEPSEEK_MODEL=deepseek-reasoner

# 生产环境填写你的前端域名（逗号分隔），开发阶段留空即允许所有来源
# ALLOWED_ORIGINS=https://fc842598.github.io,https://your-domain.com
